# AWS Credentials (never commit real values!)
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-east-1

# Terraform State Backend
TF_STATE_BUCKET=your-tf-state-bucket-name
TF_LOCK_TABLE=your-dynamodb-lock-table-name

# Prod API Key (for testing)
PROD_API_KEY=your_prod_api_key_here

# Active deployment slot (blue or green)
ACTIVE_SLOT=blue
